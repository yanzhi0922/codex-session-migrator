{
  "name": "codex-session-migrator",
  "version": "2.0.0",
  "description": "A release-ready Codex session migration toolkit with a local web app, CLI, backups, restore, and health checks.",
  "main": "src/server.js",
  "bin": {
    "codex-migrate": "src/cli.js"
  },
  "scripts": {
    "start": "node src/cli.js serve",
    "serve": "node src/cli.js serve",
    "list": "node src/cli.js list",
    "stats": "node src/cli.js stats",
    "doctor": "node src/cli.js doctor",
    "migrate": "node src/cli.js migrate",
    "restore": "node src/cli.js restore",
    "backups": "node src/cli.js backups",
    "test": "node --test"
  },
  "keywords": [
    "codex",
    "openai",
    "session",
    "migration",
    "provider",
    "jsonl",
    "backup",
    "restore"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.17.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yanzhi0922/codex-session-migrator.git"
  },
  "bugs": {
    "url": "https://github.com/yanzhi0922/codex-session-migrator/issues"
  },
  "homepage": "https://github.com/yanzhi0922/codex-session-migrator#readme"
}
