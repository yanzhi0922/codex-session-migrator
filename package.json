{
  "name": "codex-session-migrator",
  "version": "3.0.0",
  "description": "A polished Codex session migration toolkit with a local web app, CLI, repair tools, backups, restore, and portable one-click desktop releases.",
  "main": "src/cli.js",
  "bin": {
    "codex-migrate": "src/cli.js"
  },
  "scripts": {
    "start": "node --disable-warning=ExperimentalWarning src/cli.js serve",
    "serve": "node --disable-warning=ExperimentalWarning src/cli.js serve",
    "list": "node --disable-warning=ExperimentalWarning src/cli.js list",
    "stats": "node --disable-warning=ExperimentalWarning src/cli.js stats",
    "doctor": "node --disable-warning=ExperimentalWarning src/cli.js doctor",
    "repair": "node --disable-warning=ExperimentalWarning src/cli.js repair",
    "migrate": "node --disable-warning=ExperimentalWarning src/cli.js migrate",
    "restore": "node --disable-warning=ExperimentalWarning src/cli.js restore",
    "backups": "node --disable-warning=ExperimentalWarning src/cli.js backups",
    "test": "node --disable-warning=ExperimentalWarning --test",
    "build:portable:win": "node scripts/create-portable-bundle.js",
    "build:release:win": "npm run build:portable:win"
  },
  "keywords": [
    "codex",
    "openai",
    "session",
    "migration",
    "provider",
    "jsonl",
    "backup",
    "restore"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yanzhi0922/codex-session-migrator.git"
  },
  "bugs": {
    "url": "https://github.com/yanzhi0922/codex-session-migrator/issues"
  },
  "homepage": "https://github.com/yanzhi0922/codex-session-migrator#readme"
}
